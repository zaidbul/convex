FROM node:22-bullseye

RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y \
  git curl ca-certificates procps ripgrep && rm -rf /var/lib/apt/lists/*

RUN npm install -g pnpm

RUN useradd -m -u 1001 preview

# Install bun as the preview user so it's accessible
USER preview
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/home/preview/.bun/bin:${PATH}"

WORKDIR /home/preview/app
